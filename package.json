{
  "name": "nishant",
  "version": "0.1.0",
  "private": true,
  "description": "Nishant Hardware Management",
  "author": "Nishant Hardware",
  "main": "electron.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "electron": "electron electron.js",
    "electron-dev": "node start-electron.js",
    "electron-build": "next build && electron-builder",
    "db:push": "drizzle-kit push"
  },
  "build": {
    "appId": "com.nishant.hardware",
    "productName": "निशांत",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron.js",
      "package.json",
      "public/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "निशांत"
    }
  },
  "dependencies": {
    "@libsql/client": "^0.17.0",
    "arctic": "^3.7.0",
    "drizzle-orm": "^0.45.1",
    "framer-motion": "^12.38.0",
    "html2canvas": "^1.4.1",
    "jose": "^6.2.2",
    "jspdf": "^4.2.0",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^1.11.0",
    "next": "16.1.6",
    "next-auth": "^4.24.13",
    "razorpay": "^2.9.6",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "babel-plugin-react-compiler": "1.0.0",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.9",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "wait-on": "^9.0.4"
  }
}
