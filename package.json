{
  "name": "nishant",
  "version": "0.1.0",
  "private": true,
  "main": "electron.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "electron": "electron electron.js",
    "electron-dev": "concurrently \"npm run dev\" \"wait-on http-get://localhost:3000/dashboard && electron electron.js\"",
    "electron-build": "next build && electron-builder"
  },
  "build": {
    "appId": "com.nishant.hardware",
    "productName": "निशांत",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico"
    }
  },
  "dependencies": {
    "@libsql/client": "^0.17.0",
    "drizzle-orm": "^0.45.1",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.0",
    "jspdf-autotable": "^5.0.7",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "babel-plugin-react-compiler": "1.0.0",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.9",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "wait-on": "^9.0.4"
  }
}